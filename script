-- МАРКЕРИ НАД АНОМАЛІЯМИ (BillboardGui)
-- ════════════════════════════════════════════

local anomalyFolder = Workspace:WaitForChild(SETTINGS.ANOMALY_FOLDER)
local highlights    = {}   -- Highlight об'єкти
local markers       = {}   -- BillboardGui маркери

-- ── Функція додавання маркера ─────────────────
local function addMarker(obj)
    if markers[obj] then return end

    -- Отримуємо Part для прикріплення
    local part = obj:IsA("BasePart") and obj
        or obj:FindFirstChildWhichIsA("BasePart")
    if not part then return end

    -- BillboardGui — завжди дивиться на камеру
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 60, 0, 60)
    billboard.StudsOffset = SETTINGS.MARKER_OFFSET
    billboard.AlwaysOnTop = true    -- видно крізь стіни
    billboard.MaxDistance = SETTINGS.MAX_MARKER_DIST
    billboard.Adornee = part
    billboard.Parent = playerGui

    -- Іконка маркера
    local markerIcon = Instance.new("TextLabel")
    markerIcon.Size = UDim2.new(1, 0, 0.6, 0)
    markerIcon.Position = UDim2.new(0, 0, 0, 0)
    markerIcon.BackgroundTransparency = 1
    markerIcon.Text = "⚠"
    markerIcon.TextColor3 = Color3.fromRGB(255, 80, 80)
    markerIcon.TextScaled = true
    markerIcon.Font = Enum.Font.GothamBold
    markerIcon.Parent = billboard

    -- Дистанція під іконкою
    local distLabel = Instance.new("TextLabel")
    distLabel.Name = "DistLabel"
    distLabel.Size = UDim2.new(1, 0, 0.4, 0)
    distLabel.Position = UDim2.new(0, 0, 0.6, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = "? m"
    distLabel.TextColor3 = Color3.fromRGB(220, 180, 255)
    distLabel.TextScaled = true
    distLabel.Font = Enum.Font.Code
    distLabel.Parent = billboard

    markers[obj] = { billboard = billboard, distLabel = distLabel, part = part }
end

-- ── Функція видалення маркера ─────────────────
local function removeMarker(obj)
    if markers[obj] then
        markers[obj].billboard:Destroy()
        markers[obj] = nil
    end
end

-- ════════════════════════════════════════════
-- ESP (Highlight)
-- ════════════════════════════════════════════

local function addHighlight(obj)
    if highlights[obj] then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = COLORS.highlight_fill
    hl.OutlineColor = COLORS.highlight_out
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = obj
    highlights[obj] = hl
end

local function removeHighlight(obj)
    if highlights[obj] then
        highlights[obj]:Destroy()
        highlights[obj] = nil
    end
end

-- ── Оновлення ESP стану ───────────────────────
local function updateESP()
    for obj, hl in pairs(highlights) do
        hl.Enabled = state.espEnabled
    end
    -- Маркери теж
    for obj, data in pairs(markers) do
        data.billboard.Enabled = state.espEnabled
    end
    -- Оновлюємо кнопку
    espButton.Text = state.espEnabled and "ESP ✓" or "ESP ✗"
    espButton.BackgroundColor3 = state.espEnabled
        and COLORS.button_on or COLORS.button_off
end

-- ── Ініціалізація існуючих аномалій ──────────
for _, obj in ipairs(anomalyFolder:GetChildren()) do
    addHighlight(obj)
    addMarker(obj)
end

anomalyFolder.ChildAdded:Connect(function(obj)
    addHighlight(obj)
    addMarker(obj)
end)

anomalyFolder.ChildRemoved:Connect(function(obj)
    removeHighlight(obj)
    removeMarker(obj)
end)

-- ════════════════════════════════════════════
-- DRAGGABLE GUI
-- ════════════════════════════════════════════

-- Дозволяємо тягнути панель за будь-яке місце
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        state.dragging = true
        -- Зберігаємо зсув від кута
        local pos = mainFrame.AbsolutePosition
        state.dragOffset = Vector2.new(
            input.Position.X - pos.X,
            input.Position.Y - pos.Y
        )
    end
end)

mainFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        state.dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if state.dragging then
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            local vp = camera.ViewportSize
            -- Нова позиція зі збереженням зсуву
            local newX = input.Position.X - state.dragOffset.X
            local newY = input.Position.Y - state.dragOffset.Y
            -- Обмежуємо в межах екрану
            newX = math.clamp(newX, 0, vp.X - mainFrame.AbsoluteSize.X)
            newY = math.clamp(newY, 0, vp.Y - mainFrame.AbsoluteSize.Y)
            mainFrame.Position = UDim2.new(0, newX, 0, newY)
        end
    end
end)

-- ════════════════════════════════════════════
-- СЛАЙДЕР ГУЧНОСТІ — ЛОГІКА
-- ════════════════════════════════════════════

local sliderDragging = false

sliderKnob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        sliderDragging = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        sliderDragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if sliderDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local bgPos  = sliderBg.AbsolutePosition.X
        local bgSize = sliderBg.AbsoluteSize.X
        -- Відсоток від 0 до 1
        local pct = math.clamp((input.Position.X - bgPos) / bgSize, 0, 1)
        state.soundVolume = pct
        anomalySound.Volume = pct
        -- Оновлюємо слайдер візуально
        sliderFill.Size = UDim2.new(pct, 0, 1, 0)
        sliderKnob.Position = UDim2.new(pct, -9, 0.5, -9)
        volumeLabel.Text = "🔊 Гучність: " .. math.floor(pct * 100) .. "%"
    end
end)

