-- ════════════════════════════════════════════
-- AUTO-HIDE ЛОГІКА
-- ════════════════════════════════════════════

local function startAutoHide()
    -- Скасовуємо попередній таймер
    if state.autoHideTimer then
        task.cancel(state.autoHideTimer)
    end
    state.autoHideTimer = task.delay(SETTINGS.AUTO_HIDE_DELAY, function()
        if state.currentCount == 0 and not state.isMinimized then
            -- Плавно ховаємо
            TweenService:Create(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {
                BackgroundTransparency = 1
            }):Play()
            TweenService:Create(label, TweenInfo.new(0.5), { TextTransparency = 1 }):Play()
            TweenService:Create(iconLabel, TweenInfo.new(0.5), { TextTransparency = 1 }):Play()
        end
    end)
end

local function showPanel()
    -- Скасовуємо авто-ховання
    if state.autoHideTimer then
        task.cancel(state.autoHideTimer)
        state.autoHideTimer = nil
    end
    TweenService:Create(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {
        BackgroundTransparency = 0
    }):Play()
    TweenService:Create(label, TweenInfo.new(0.5), { TextTransparency = 0 }):Play()
    TweenService:Create(iconLabel, TweenInfo.new(0.5), { TextTransparency = 0 }):Play()
end

-- ════════════════════════════════════════════
-- АНІМАЦІЇ (pulse, warning shake)
-- ════════════════════════════════════════════

local isPulsing = false

local function playPulse()
    if isPulsing then return end
    isPulsing = true
    for i = 1, 3 do
        TweenService:Create(mainFrame, TweenInfo.new(SETTINGS.PULSE_SPEED/2, Enum.EasingStyle.Sine),
            { BackgroundTransparency = 0.8 }):Play()
        task.wait(SETTINGS.PULSE_SPEED / 2)
        TweenService:Create(mainFrame, TweenInfo.new(SETTINGS.PULSE_SPEED/2, Enum.EasingStyle.Sine),
            { BackgroundTransparency = 0 }):Play()
        task.wait(SETTINGS.PULSE_SPEED / 2)
    end
    isPulsing = false
end

local function playWarningShake()
    local base = mainFrame.Position
    for i = 1, 4 do
        TweenService:Create(mainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear),
            { Position = UDim2.new(base.X.Scale, base.X.Offset - 8,
                                   base.Y.Scale, base.Y.Offset) }):Play()
        task.wait(0.05)
        TweenService:Create(mainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear),
            { Position = UDim2.new(base.X.Scale, base.X.Offset + 8,
                                   base.Y.Scale, base.Y.Offset) }):Play()
        task.wait(0.05)
    end
    TweenService:Create(mainFrame, TweenInfo.new(0.1, Enum.EasingStyle.Sine),
        { Position = base }):Play()
end

-- ════════════════════════════════════════════
-- ОНОВЛЕННЯ GUI (від сервера)
-- ════════════════════════════════════════════

local function updateGui(count, isNew)
    state.currentCount = count
    local isWarning = count >= SETTINGS.WARNING_THRESHOLD

    -- Показуємо панель якщо є аномалії
    if count > 0 then
        showPanel()
    else
        startAutoHide()
    end

    label.Text = "Аномалій: " .. count

    -- Колір тексту
    if isWarning then
        TweenService:Create(label, TweenInfo.new(0.3), { TextColor3 = COLORS.warning_text }):Play()
        TweenService:Create(textStroke, TweenInfo.new(0.3), { Color = COLORS.stroke_warning }):Play()
        if blurEnabled then setBlur(true) end
    else
        TweenService:Create(label, TweenInfo.new(0.3), { TextColor3 = COLORS.normal_text }):Play()
        TweenService:Create(textStroke, TweenInfo.new(0.3), { Color = COLORS.stroke_normal }):Play()
        setBlur(false)
    end

    -- Ефекти при новій аномалії
    if isNew then
        anomalySound:Play()
        task.spawn(playPulse)
        if isWarning then task.spawn(playWarningShake) end
    end
end

-- ════════════════════════════════════════════
-- RUNSERVICE LOOP (FPS + Rainbow + Дистанції)
-- ════════════════════════════════════════════

local fpsTimer   = 0
local fpsFrames  = 0
local lastFPS    = 60

RunService.RenderStepped:Connect(function(dt)
    -- ── FPS лічильник ──────────────────────────
    fpsFrames = fpsFrames + 1
    fpsTimer  = fpsTimer  + dt
    if fpsTimer >= 0.5 then  -- оновлення кожні 0.5 сек
        lastFPS   = math.floor(fpsFrames / fpsTimer)
        fpsFrames = 0
        fpsTimer  = 0
        -- Колір залежно від FPS
        local fpsColo = lastFPS >= 50 and Color3.fromRGB(100, 255, 100)
            or lastFPS >= 30 and Color3.fromRGB(255, 220, 50)
            or Color3.fromRGB(255, 80, 80)
        fpsLabel.TextColor3 = fpsColo
        fpsLabel.Text = "FPS: " .. lastFPS
    end

    -- ── Rainbow Glow ───────────────────────────
    if rainbowEnabled then
        state.rainbowHue = (state.rainbowHue + dt * 0.15) % 1  -- повільна зміна
        local rainbowColor = Color3.fromHSV(state.rainbowHue, 1, 1)
        frameStroke.Color = rainbowColor
        textStroke.Color  = rainbowColor
        miniStroke.Color  = rainbowColor
    end

    -- ── Оновлення дистанцій ────────────────────
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")

    for obj, data in pairs(markers) do
        if hrp and data.part and data.part.Parent then
            local dist = (hrp.Position - data.part.Position).Magnitude
            data.distLabel.Text = math.floor(dist) .. " m"
            -- Колір дистанції: червоний якщо близько
            data.distLabel.TextColor3 = dist < 20
                and Color3.fromRGB(255, 80, 80)
                or Color3.fromRGB(220, 180, 255)
        end
    end
end)

